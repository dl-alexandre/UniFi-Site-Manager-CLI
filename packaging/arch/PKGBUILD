# Maintainer: Dalton Alexandre <dalexandre@milcgroup.info>
pkgname=usm-cli
pkgver=0.0.3
pkgrel=1
pkgdesc="UniFi Site Manager CLI for cloud API management"
arch=('x86_64' 'aarch64')
url="https://github.com/dl-alexandre/UniFi-Site-Manager-CLI"
license=('MIT')
depends=()
makedepends=('go')
source=("$pkgname-$pkgver.tar.gz::https://github.com/dl-alexandre/UniFi-Site-Manager-CLI/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$pkgname-$pkgver"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external -mod=readonly -modcacherw"
  go build -o usm ./cmd/usm
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 usm "$pkgdir/usr/bin/usm"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
